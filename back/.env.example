# ===== ローカルDB（Docker postgres）=====
# docker compose の db サービスと app の接続先で共有する。
POSTGRES_USER=trade
POSTGRES_PASSWORD=trade
POSTGRES_DB=trade_analyzer

# アプリのDB接続先。
# - ローカル（docker compose）: db サービスを指す（下記のまま）
# - Neonに接続する場合: 下行を空にして NEON_DATABASE_URL を設定する
DATABASE_URL=postgresql://trade:trade@db:5432/trade_analyzer?sslmode=disable

# Neon（本番/ステージング）。DATABASE_URL が未設定の場合に使用される。
NEON_DATABASE_URL=

# ===== アプリ =====
# production のとき Cookie に Secure を付与
APP_ENV=development
# 本番フロントのオリジン（CORS許可用）
FRONTEND_ORIGIN=

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=30

# ===== Claude API =====
# 未設定（または xxxxx を含むプレースホルダ）の場合はスタブ動作（外部通信なし）。
ANTHROPIC_API_KEY=sk-ant-xxxxx
# 毎日分析(RunScheduled)で使うモデル。未指定時は claude-sonnet-4-6（高頻度・コスト重視）。
ANTHROPIC_MODEL=
# 週次学習(RunWeekly)で使うモデル。未指定時は claude-opus-4-8（低頻度・高レバレッジ・推論重視）。
# 週次は月4回程度のためOpusでもコスト増はわずか。Sonnetに揃えたい場合は claude-sonnet-4-6 を指定。
ANTHROPIC_MODEL_WEEKLY=
# 任意。1レスポンスの最大トークン数（未指定時は 2048）。
ANTHROPIC_MAX_TOKENS=

# ===== LINE =====
LINE_CHANNEL_ACCESS_TOKEN=xxxxx
LINE_USER_ID=xxxxx

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=trading-system-learning

# ===== 内部API認証（Lambda → Go）=====
INTERNAL_API_SECRET=xxxxx
